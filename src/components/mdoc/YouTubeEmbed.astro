---
// From Blogster https://github.com/flexdinesh/blogster
// MIT LICENSE: https://github.com/flexdinesh/blogster/blob/main/LICENSE
type Props = {
  url: string;
  label: string;
};

const { url, label } = Astro.props;
---

<div>
    <iframe
            class="aspect-video w-full"
            src={url}
            title={label}
            frame-border="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
    >
    </iframe>
</div>
